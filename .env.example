# Environment Variables for LinkSphere

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ============================================
# JWT SECRET (REQUIRED FOR SECURITY)
# ============================================
# Generate a secure secret with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# IMPORTANT: Change this in production! Use a strong random secret.
JWT_SECRET=change-this-to-a-strong-secret-key-minimum-32-characters

# ============================================
# SITE CONFIGURATION
# ============================================
# Your site URL (used for API calls and redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# RATE LIMITING (OPTIONAL)
# ============================================
# For production rate limiting, consider using Upstash Redis:
# https://upstash.com/
# Leave empty to use in-memory rate limiting (development only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================
# NODE ENVIRONMENT
# ============================================
# Development: development
# Production: production
NODE_ENV=development
